<?xml version="1.0" encoding="UTF-8"?>

<addon
    id="plugin.video.moda"
    name="Moda"
    version="0.1.0"
    provider-name="donyila">

    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
    </requires>

    <extension
        point="xbmc.python.pluginsource"
        library="main.py">

        <provides>video</provides>

    </extension>

    <extension point="xbmc.addon.metadata">

        <summary lang="en_GB">
            Moda Video Plugin
        </summary>

        <description lang="en_GB">
            Browse and stream remote movies.
        </description>

        <platform>all</platform>

    </extension>

</addon>