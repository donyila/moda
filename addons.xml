<?xml version="1.0" encoding="UTF-8"?>
<addons>
<addon id="repository.moda"
       name="MODA Repository"
       version="1.0.0"
       provider-name="donyila">

    <requires>
        <import addon="xbmc.addon" version="21.0.0"/>
    </requires>

    <extension point="xbmc.addon.repository"
               name="MODA Repository">

        <dir>
            <info compressed="false">
                https://raw.githubusercontent.com/donyila/moda/main/addons.xml
            </info>

            <checksum>
                https://raw.githubusercontent.com/donyila/moda/main/addons.xml.md5
            </checksum>

            <datadir zip="true">
                https://raw.githubusercontent.com/donyila/moda/main/zips/
            </datadir>
        </dir>

    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>MODA Kodi Repository</summary>
        <description>Official repository for MODA Kodi add-ons.</description>

        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>

        <platform>all</platform>
    </extension>

</addon>
<addon
    id="plugin.video.moda"
    name="Moda"
    version="1.1.2"
    provider-name="donyila">

    <requires>
        <import addon="xbmc.python" version="3.0.1"/>
        <import
        addon="metadata.movies.thetvdb.com.v4.python"
        version="1.0.0"
        />
    </requires>

    <extension
        point="xbmc.python.pluginsource"
        library="main.py">

        <provides>video</provides>

    </extension>

    <extension point="xbmc.addon.metadata">

        <summary lang="en_GB">
            Moda Video Plugin
        </summary>

        <description lang="en_GB">
            Browse and stream remote movies.
        </description>

	<assets>
		<icon>icon.png</icon>
	</assets>

        <platform>all</platform>

    </extension>

    <extension
        point="xbmc.service"
        library="service.py"
        start="startup">
    </extension>

</addon>
</addons>
